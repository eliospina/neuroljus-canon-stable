# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must never be committed.

# Server-side OpenAI key used by /api/chat (required for the AI chat).
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxx

# Public Web3Forms access key used by the contact form.
# Required for the contact form to work; if unset the form is disabled
# and shows a fallback email. Get one at https://web3forms.com
NEXT_PUBLIC_WEB3FORMS_KEY=
